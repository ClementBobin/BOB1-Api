<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="${basedir}/internal-nlog-AspNetCore.txt">

  <extensions>
    <add assembly="NLog.Web.AspNetCore"/>
  </extensions>

  <targets>
    <!-- All logs -->
    <target xsi:type="File" name="allfile"
            fileName="${basedir}/logs/nlog-Bob1-all-${shortdate}.log"
            layout="${longdate}|${event-properties:item=EventId:whenEmpty=0}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />

    <!-- Application logs only -->
    <target xsi:type="File" name="ownfile-web"
            fileName="${basedir}/logs/nlog-Bob1-own-${shortdate}.log"
            layout="${longdate}|${event-properties:item=EventId:whenEmpty=0}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}|url: ${aspnet-request-url}|action: ${aspnet-mvc-action}|${callsite}" />

    <!-- Console -->
    <target xsi:type="Console" name="console"
            layout="${MicrosoftConsoleLayout}" />
  </targets>

  <rules>
    <!-- Application logs (Info+) -->
    <logger name="Bob1.*" minlevel="Info" writeTo="allfile,ownfile-web,console" />
    <logger name="Api.*" minlevel="Info" writeTo="allfile,ownfile-web,console" />
    <logger name="Infrastructure.*" minlevel="Debug" writeTo="allfile,ownfile-web,console" />
    <logger name="Application.*" minlevel="Debug" writeTo="allfile,ownfile-web,console" />

    <!-- Microsoft — Warning+ except Hosting.Lifetime -->
    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <logger name="Microsoft.Hosting.Lifetime" minlevel="Info" writeTo="allfile,ownfile-web,console" final="true" />
    <logger name="System.Net.Http.*" maxlevel="Info" final="true" />

    <!-- Catch-all -->
    <logger name="*" minlevel="Warn" writeTo="allfile,console" />
  </rules>
</nlog>
